# Backend / scripts environment
# Keep separate .env files or secret stores for prod and dev.
# Never commit real values.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NOLIO_EMAIL=your-nolio-email
NOLIO_PASSWORD=your-nolio-password
OPENWEATHER_API_KEY=your-openweather-api-key

# Optional secrets used by some edge functions / integrations
NOLIO_CLIENT_ID=your-nolio-client-id
NOLIO_CLIENT_SECRET=your-nolio-client-secret
NOLIO_REFRESH_TOKEN=your-nolio-refresh-token
NOLIO_PARTNER_ID=your-nolio-partner-id
GITHUB_PAT=your-github-pat
RESEND_API_KEY=your-resend-api-key
STORAGE_ALERT_EMAIL=alerts@example.com
